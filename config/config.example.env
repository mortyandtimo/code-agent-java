# Copy this file to `config/local.env` before local use.
# Fill placeholders with your own values.

# Server
SERVER_PORT=18081

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/code_agent_java?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=YOUR_DB_USER
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD
SPRING_FLYWAY_ENABLED=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# LLM
CODE_AGENT_API_KEY=YOUR_API_KEY
CODE_AGENT_LLM_BASE_URL=https://api.openai.com/v1
CODE_AGENT_LLM_MODEL=gpt-4o-mini
CODE_AGENT_LLM_TIMEOUT_SECONDS=90
CODE_AGENT_LLM_MAX_RETRIES=2
CODE_AGENT_LLM_INITIAL_BACKOFF_MILLIS=1500
CODE_AGENT_LLM_MAX_BACKOFF_MILLIS=8000

# CLI
CODE_AGENT_CLI_ENABLED=true
CODE_AGENT_SHELL_TIMEOUT_SECONDS=30
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8
